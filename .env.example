# ── Jira Readiness Agent — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in all values before running the application.
# Never commit .env to version control.

# ── API Auth ───────────────────────────────────────────────────────────────────
# Shared secret used by Jira Automation to authenticate webhook calls.
# Set this value in Jira Automation > Send web request > Headers > X-API-Key
API_KEY=

# ── Jira ──────────────────────────────────────────────────────────────────────
# Base URL of your Jira Cloud instance — no trailing slash
JIRA_BASE_URL=https://your-domain.atlassian.net

# Jira user email associated with the API token below
JIRA_USER_EMAIL=

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Anthropic API key — generate at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Langfuse (self-hosted via Docker) ─────────────────────────────────────────
# These values are pre-configured to work with docker-compose out of the box.
# On first boot, Langfuse auto-creates an org, project, user, and API keys.
# Login at http://localhost:3000 with the email/password below.

# SDK reads these automatically — must match LANGFUSE_INIT_PROJECT keys below
LANGFUSE_PUBLIC_KEY=lf-pk-local
LANGFUSE_SECRET_KEY=lf-sk-local
LANGFUSE_HOST=http://localhost:3000

# Auto-seed config — creates org, project, and user on first Docker boot
LANGFUSE_INIT_ORG_NAME=local
LANGFUSE_INIT_ORG_ID=local-org
LANGFUSE_INIT_PROJECT_NAME=jira-readiness
LANGFUSE_INIT_PROJECT_ID=local-project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf-pk-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf-sk-local
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_PASSWORD=password

# Internal Langfuse secrets — no need to change for local dev
LANGFUSE_NEXTAUTH_SECRET=local-nextauth-secret-do-not-use-in-prod
LANGFUSE_SALT=local-salt-do-not-use-in-prod

# ── Postgres (Langfuse dependency) ────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
